{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(glab:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git ls-files:*)",
      "Bash(git remote:*)",
      "Bash(git symbolic-ref:*)",
      "Bash(git fetch:*)",
      "Bash(git worktree:*)",
      "Bash(kubectl:*)",
      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(docker-compose:*)",
      "Skill",
      "Glob",
      "Grep",
      "Task",
      "TodoWrite",
      "ExitPlanMode",
      "NotebookEdit",
      "KillShell",
      "TaskOutput",
      "mcp__atlassian-mcp-server",
      "mcp__trino-mcp"
    ],
    "ask": [
      "mcp__slack-direct__send_message",
      "mcp__atlassian-mcp-server__addCommentToJiraIssue",
      "mcp__atlassian-mcp-server__createConfluenceFooterComment",
      "mcp__atlassian-mcp-server__createConfluenceInlineComment",
      "Bash(glab mr approve:*)",
      "Bash(glab mr merge:*)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "~/projects/shopback/"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/wezterm-notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {},
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "gitlab.com",
        "*.shopback.com",
        "shopback.com"
      ],
      "allowUnixSockets": [
        "~/.gnupg/S.gpg-agent"
      ],
      "allowLocalBinding": true
    },
    "excludedCommands": [
      "git",
      "glab",
      "kubectl",
      "make",
      "docker",
      "docker-compose",
      "docker compose",
      "npm",
      "yarn",
      "gpg"
    ],
    "allowUnsandboxedCommands": true
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754208364998
  },
  "model": "sonnet[1m]"
}
