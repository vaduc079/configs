{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(glab:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git ls-files:*)",
      "Bash(git remote:*)",
      "Bash(git symbolic-ref:*)",
      "Bash(git fetch:*)",
      "Bash(git worktree:*)",
      "Bash(kubectl:*)",
      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(docker-compose:*)",
      "Skill",
      "Glob",
      "Grep",
      "TodoWrite",
      "ExitPlanMode",
      "NotebookEdit",
      "KillShell",
      "TaskOutput",
      "mcp__atlassian-mcp-server",
      "mcp__claude_ai_Slack"
    ],
    "ask": [
      "mcp__slack-direct__send_message",
      "mcp__claude_ai_Slack__slack_schedule_message",
      "mcp__claude_ai_Slack__slack_send_message",
      "mcp__claude_ai_Slack__slack_send_message_draft",
      "mcp__claude_ai_Slack__slack_create_canvas",
      "mcp__atlassian-mcp-server__addCommentToJiraIssue",
      "mcp__atlassian-mcp-server__createConfluenceFooterComment",
      "mcp__atlassian-mcp-server__createConfluenceInlineComment",
      "mcp__atlassian-mcp-server__updateConfluencePage",
      "Bash(glab mr approve:*)",
      "Bash(glab mr merge:*)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "~/projects/shopback/"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/claude-code-notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "codex@openai-codex": false
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "gitlab.com",
        "*.shopback.com",
        "shopback.com",
        "localhost",
        "127.0.0.1"
      ],
      "allowUnixSockets": [
        "~/.gnupg/S.gpg-agent",
        "~/.rd/docker.sock"
      ],
      "allowLocalBinding": true
    },
    "excludedCommands": [
      "git *",
      "glab *",
      "kubectl *",
      "docker *",
      "docker-compose *",
      "docker compose *",
      "gpg *",
      "agent-to-agent *"
    ]
  },
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "vim",
  "teammateMode": "auto",
  "skipAutoPermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754208364998
  },
  "model": "sonnet[1m]"
}
