#!/bin/sh

alias ls='ls --color=auto'
alias ll='ls -lavh'
alias l='ls -lAvh --ignore=.\?\*'

alias load_zshrc='source ~/.zshrc'

#######
# vim #
#######

alias vim='nvim'
alias vi='nvim'

##########################
# Update/install scripts #
##########################

# starship - shell prompt
alias update_starship='curl -sS https://starship.rs/install.sh | sh'
alias update_kitty='curl -L https://sw.kovidgoyal.net/kitty/installer.sh | sh /dev/stdin'
